#!/usr/bin/env python3
import requests
from bs4 import BeautifulSoup
import sys
import os

# Colores ANSI
RED = "\033[91m"
GREEN = "\033[92m"
WHITE = "\033[97m"
RESET = "\033[0m"

def validar_archivo(html_file):
    if not os.path.isfile(html_file):
        print("no lo encuentro cabeza almendra ¿existe?¿es la ruta?¿esta mal escrito?")
        sys.exit(1)

    if not html_file.lower().endswith((".html", ".htm")):
        print("error, e dado error porque eres tonto y me has pasado un archivo que no es un html cabezon.")
        sys.exit(1)

def es_html_real(path):
    try:
        with open(path, "r", encoding="utf-8", errors="ignore") as f:
            inicio = f.read(500).lower()
            return "<html" in inicio or "<!doctype html" in inicio
    except:
        return False

def check_link(url):
    headers = {"User-Agent": "Mozilla/5.0"}
    try:
        r = requests.head(url, headers=headers, allow_redirects=True, timeout=8)
        if r.status_code >= 400:
            r = requests.get(url, headers=headers, timeout=8)
        return r.status_code < 400
    except requests.RequestException:
        return False

def main(html_file):
    validar_archivo(html_file)

    if not es_html_real(html_file):
        print("error, e dado error porque eres tonto y me has pasado un archivo que no es un html cabezon.")
        sys.exit(1)

    with open(html_file, "r", encoding="utf-8") as f:
        soup = BeautifulSoup(f, "html.parser")

    broken_links = []

    print("\n[+] Comprobando enlaces...\n")

    for link in soup.find_all("a", href=True):
        url = link["href"]

        if url.startswith("#") or url.startswith("javascript:"):
            continue

        print(f"Comprobando: {WHITE}{url}{RESET}")

        if not check_link(url):
            print(f"{RED}:( ROTO → {url}{RESET}")
            broken_links.append(link)
        else:
            print(f"{GREEN}:) OK → {WHITE}{url}{RESET}")

    print(f"\n[+] Enlaces rotos encontrados: {len(broken_links)}")

    if broken_links:
        choice = input("¿Eliminar enlaces rotos? (s/n): ").lower()

        if choice == "s":
            for link in broken_links:
                link.decompose()

            output = "cleaned_" + os.path.basename(html_file)

            with open(output, "w", encoding="utf-8") as f:
                f.write(str(soup))

            print(f"{GREEN}[+] Archivo guardado: {output}{RESET}")
        else:
            print("[+] No se eliminó nada.")
    else:
        print(f"{GREEN}[+] No hay enlaces rotos.{RESET}")

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print(f"Uso: {sys.argv[0]} archivo.html")
    else:
        main(sys.argv[1])
